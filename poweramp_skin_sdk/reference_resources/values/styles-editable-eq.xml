<resources
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools"
	>

	<style name="EqEditableButtonContainer" parent="EditableButtonContainer">
		<item name="layout_widthPercent">33.33%</item>
	</style>

	<style name="EqButtonsBase">
		<!-- Allow buttons to overflow during scenes -->
		<item name="android:clipToPadding">false</item>

		<!-- This defines TopSubAAButtons height - it may be also 2x of this if "2 lines" option is activated -->
		<item name="slotLineHeight">@dimen/EqButton_height</item>
		<!-- This defines default slot size -->
		<item name="slotWidth">@dimen/EqButton_width</item><!-- 64dp -->
		<!-- The space between slots. Not applied to the first left or last right slot -->
		<item name="slotPadding">4dp</item>

		<!-- "Small" slot width. Height stays the same -->
		<item name="smallSlotWidth">@dimen/EqButtonsBase_smallSlotWidth</item><!-- == EqButton_width / 1.39 -->

		<!-- The padding between 2 slot lines in "2 lines" mode -->
		<item name="slotLinePadding">4dp</item>

		<!-- The drawable used to indicate the slot during the edit -->
		<item name="slotDrawable">@drawable/slot</item>

		<!-- The drawable used to indicate the hightlighted slot during the edit -->
		<item name="highlightedSlotDrawable">@drawable/slot_highlighted</item>

		<item name="loadableDraggable">@+id/behavior_eqbuttons_edit</item>

		<item name="topSceneContainer">@id/top_eq_tab_container</item>

	</style>

	<!-- Overridden for land -->
	<style name="EqButtons" parent="EqButtonsBase">
		<item name="android:layout_width">wrap_content</item>
		<item name="android:layout_height">0dp</item>
		<item name="layout_attachTopToTop">@id/eq_tone_panel_spacer</item>
		<item name="layout_attachBottom">parent</item>
		<item name="layout_attachLeft">parent</item>
		<item name="android:layout_marginLeft">8dp</item>
	</style>

	<!-- Overridden for land -->
	<style name="EqButtonsEditTopContainer">
		<!-- Required as we run own transitions inside -->
		<item name="privateScene">true</item>
		<item name="android:layout_width">0dp</item>
		<item name="layout_maxWidth">600dp</item>
		<item name="android:layout_height">0dp</item>
		<item name="layout_attachLeft">@id/eq_buttons</item>
		<item name="layout_attachTopToTop">@id/eq_buttons</item>
		<item name="android:layout_marginTop">-52dp</item><!-- Grow over top button by ~height of top buttons in the edit panel -->
		<item name="layout_attachBottom">parent</item>
		<item name="layout_attachRight">inset</item>
		<item name="android:layout_marginLeft">4dp</item>
	</style>

	<style name="EqButtonsEditTwoLinesCheckBox" parent="SubAAButtonsEditCheckBoxBase">
		<item name="layout_widthPercent">50%</item>
	</style>

	<style name="EditableEqCheckButton" parent="EqCheckButton">
		<item name="android:layout_marginLeft">0dp</item><!-- Erase possible margins -->
	</style>

	<!-- Eq button with the icon for the "normal" size. No Tint -->
	<style name="EditableDSPCheckboxWithIcon" parent="EditableEqCheckButton">
		<item name="drawableOnly">true</item>
		<item name="drawablePosition">gravityNoPads</item>
	</style>

	<!-- Eq button without icon for the "normal" size -->
	<style name="EditableDSPCheckboxNoIcon" parent="EditableEqCheckButton">
		<item name="drawableOnly">false</item>
		<item name="drawablePosition">left</item><!-- Actually we don't have icon, but nevertheless, setup its possible layout -->
		<item name="android:drawable">@color/no_drawable0000</item>
		<!-- Avoid ellipsis, esp. during anims -->
		<item name="android:ellipsize">none</item>
	</style>

	<!-- Scene for Eq button with icon for the "small" size. The icon itself is set by the button code -->
	<style name="EditableDSPCheckboxTinted_scene_small">
		<item name="drawableOnly">true</item>
		<item name="drawablePosition">gravityNoPads</item>
		<item name="applyViewParams">true</item>
		<item name="drawableTint">?colorIconLessContrast</item>
	</style>

	<!-- No explicit tint here, the drawable itself has a tint -->
	<style name="EditableDSPCheckbox_scene_small">
		<item name="drawableOnly">true</item>
		<item name="drawablePosition">gravityNoPads</item>
		<item name="applyViewParams">true</item>
		<item name="drawableTint">@null</item>
		<!-- Avoid ellipsis, esp. during anims -->
		<item name="android:ellipsize">none</item>
	</style>

	<style name="EditableEqVisButton" parent="PeqVisButtonLayoutBase">
		<item name="android:layout_width">@dimen/EqButton_width</item>
		<item name="android:layout_height">@dimen/EqButton_height</item>
		<item name="drawableWidth">24dp</item>
		<item name="drawableHeight">24dp</item>
	</style>


</resources>