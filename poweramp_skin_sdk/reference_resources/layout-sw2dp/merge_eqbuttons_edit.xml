<merge xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools"
	xmlns:w="http://schemas.android.com/apk/res-auto"
	>

<com.maxmpz.widget.base.Shim
	style="@style/SubAAButtonsEditShim"
	/>

<!-- NOTE: popup buttons generally require the scene layout somewhere in the parent containers -->
<!-- NOTE: empty scenes are needed for a smoother animation so child views are animated in the parent during the
	 appearance scene -->
<com.maxmpz.widget.base.SceneFastLayout
	style="@style/EqButtonsEditTopContainer"
	>

	<com.maxmpz.widget.base.FastLayout android:id="@+id/sub_aa_buttons_edit_panel"
		style="@style/SubAAButtonsEditPanel"
		>
		<com.maxmpz.widget.base.BusActionButton
			style="@style/SubAAButtonsSettingsButton"
			w:busId="@id/bus_app_cmd"
			w:msgId="@id/cmd_app_open_settings"
			w:string="peq_ui#edit_eq_buttons"
			android:contentDescription="@string/settings"
			/>
		<SceneParams w:scene="@+id/scene_visible"/>

		<com.maxmpz.widget.base.FastLayout android:id="@+id/dialog_buttons"
			style="@style/SubAAButtonsEditDialogButtons"
			>
			<com.maxmpz.widget.base.BusCheckBox android:id="@+id/two_lines"
				style="@style/EqButtonsEditTwoLinesCheckBox"

				android:text="@string/two_columns"

				w:stateBusId="@+id/eq_buttons"
				w:stateMsgId="@+id/state_two_lines"
				w:booleanStateId="@+id/state_two_lines"
				w:checkCmdId="@+id/cmd_set_two_lines"
				w:uncheckCmdId="@+id/cmd_set_two_lines"
				w:sendBooleanArg="checkedArg1"
				/>
			<SceneParams w:scene="@+id/scene_visible"/>

		</com.maxmpz.widget.base.FastLayout>
		<SceneParams w:scene="@+id/scene_visible"/>

		<com.maxmpz.widget.base.FastLayout
			style="@style/SubAAButtonsEditScrollableCont"
			>

			<!-- NOTE: scene layout, as we run default<->small transition here -->
			<com.maxmpz.widget.base.SceneFastLayout android:id="@+id/edit_buttons_cont"
				style="@style/SubAAButtonsEditButtonsCont"
				>

				<com.maxmpz.widget.player.DraggableSourceBehavior
					w:draggingContainer="@+id/top_container"
					w:draggingTarget="@+id/eq_buttons"
					w:draggableButtons="@array/eq_buttons"
					w:draggableButtonContainerStyle="@style/EqEditableButtonContainer"
					w:draggableButtonLabelStyle="@style/EditableButtonLabel"
					/>


			</com.maxmpz.widget.base.SceneFastLayout>
			<SceneParams w:scene="@+id/scene_visible"/>

			<com.maxmpz.widget.base.ScrollingBehavior
				w:disallowParentScroll="true"
				w:noScrollbars="true"
				/>
		</com.maxmpz.widget.base.FastLayout>
		<SceneParams w:scene="@+id/scene_visible"/>

		<TextView android:id="@+id/hint"
			style="@style/SubAAButtonsEditHint"
			android:text="@string/hold_and_drag_buttons"
			/>
		<SceneParams w:scene="@+id/scene_visible"/>

	</com.maxmpz.widget.base.FastLayout>
	<SceneParams w:scene="@+id/scene_visible"
		style="@style/SubAAButtonsEditPanel_scene_visible"
		/>

	<!-- Required for smooth dialog animation during 1-2lines transition -->
	<SceneParams w:forId="parent" w:scene="defaultScene" w:scene_2="@id/scene_vis_temp_ui"
		w:scene_3="@id/scene_vis_w_ui" w:scene_4="@id/scene_vis"
		w:recalcChildren="dynamic"
		/>
</com.maxmpz.widget.base.SceneFastLayout>
</merge>